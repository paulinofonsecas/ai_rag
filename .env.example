## Porta do servidor backend
PORT=3000

## Configurações do banco de dados para chat e produtos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hybrid_search
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=20

## Configurações do Redis (fila, cache, workers)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

## API de embeddings para busca semântica e chat
EMBEDDING_API_KEY=my-api
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536

## Configurações de rerank para busca híbrida
RERANK_MODEL=gemini-2.5-flash
RERANK_MAX_CANDIDATES=40
RERANK_MAX_RETRIES=2
RERANK_BACKOFF_MS=400
RERANK_COOLDOWN_MS=10000
RERANK_CACHE_TTL_MS=30000

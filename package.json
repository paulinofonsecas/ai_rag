{
    "name": "ai-rag-hybrid-search",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "nest build",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:worker": "ts-node -r tsconfig-paths/register src/workers/main.worker.ts",
        "start:worker:dev": "node --watch --require ts-node/register --require tsconfig-paths/register src/workers/main.worker.ts",
        "playground": "ts-node -r tsconfig-paths/register src/playground/cli.ts",
        "seed:products": "ts-node -r tsconfig-paths/register src/seeds/products.seed.ts",
        "seed:products:files": "ts-node -r tsconfig-paths/register src/seeds/products-files.seed.ts",
        "lint": "eslint \"src/**/*.ts\"",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage --runInBand"
    },
    "dependencies": {
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "bullmq": "^5.7.8",
        "cache-manager": "^6.4.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "ioredis": "^5.4.1",
        "pg": "^8.12.0",
        "pino": "^9.5.0",
        "pino-http": "^10.3.0"
    },
    "devDependencies": {
        "@jridgewell/sourcemap-codec": "^1.5.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/jest": "^29.5.12",
        "@types/express": "^5.0.0",
        "@types/node": "^22.7.7",
        "@types/pg": "^8.11.10",
        "eslint": "^9.12.0",
        "jest": "^29.7.0",
        "prettier": "^3.3.3",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.6.3"
    }
}